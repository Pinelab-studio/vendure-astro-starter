---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Navigation from "../../../components/Navigation.astro";
import Footer from "../../../components/Footer.astro";
import { BreadcrumbSlash } from "../../../components/icons/BreadcrumbSlash";
import { getProductBySlug } from "../../../lib/server/product-service";

const product = await getProductBySlug(Astro.locals.locale, Astro.params.product!);
if (!product) {
  return Astro.redirect(`/404`);
}
console.log(product.collections);
---

<BaseLayout
  title="Product"
  metaTitle="Product"
  metaDescription="Product detail"
>
  <Navigation />

  <main>
    <div class="py-12">
      <nav
        aria-label="Breadcrumb"
        class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"
      >
        <ol role="list" class="flex items-center space-x-4">
          <li>
            <div class="flex items-center">
              <a href="#" class="mr-4 text-sm font-medium text-base-content"
                >Women</a
              >
              <BreadcrumbSlash className="h-5 w-auto" />
            </div>
          </li>
          <li>
            <div class="flex items-center">
              <a href="#" class="mr-4 text-sm font-medium text-base-content"
                >Clothing</a
              >
              <BreadcrumbSlash className="h-5 w-auto" />
            </div>
          </li>

          <li class="text-sm">
            <a
              href="#"
              aria-current="page"
              class="font-medium text-base-content/70 hover:text-base-content"
              >Basic Tee</a
            >
          </li>
        </ol>
      </nav>
    </div>

    <div
      class="mx-auto max-w-2xl px-4 pb-16 sm:px-6 sm:pb-24 lg:max-w-7xl lg:px-8"
    >
      <div class="lg:grid lg:grid-cols-2 lg:items-start lg:gap-x-8">
        <!-- Image gallery -->
        <div class="flex flex-col-reverse">
          <div
            class="mx-auto mt-6 hidden w-full max-w-2xl sm:block lg:max-w-none"
          >
            <div class="grid grid-cols-4 gap-6">
              <div
                class="bg-base-200 relative flex h-24 cursor-pointer items-center justify-center rounded-lg"
              >
                <span class="sr-only">Angled view</span>
                <span class="absolute inset-0 overflow-hidden rounded-lg">
                  <img
                    src="https://tailwindcss.com/plus-assets/img/ecommerce-images/product-page-03-product-01.jpg"
                    alt=""
                    class="size-full object-cover"
                  />
                </span>
              </div>
              <div
                class="bg-base-200 relative flex h-24 cursor-pointer items-center justify-center rounded-lg"
              >
                <span class="sr-only">Front view</span>
                <span class="absolute inset-0 overflow-hidden rounded-lg">
                  <img
                    src="https://tailwindcss.com/plus-assets/img/ecommerce-images/product-page-03-product-02.jpg"
                    alt=""
                    class="size-full object-cover"
                  />
                </span>
              </div>
              <div
                class="bg-base-200 relative flex h-24 cursor-pointer items-center justify-center rounded-lg"
              >
                <span class="sr-only">Back view</span>
                <span class="absolute inset-0 overflow-hidden rounded-lg">
                  <img
                    src="https://tailwindcss.com/plus-assets/img/ecommerce-images/product-page-03-product-03.jpg"
                    alt=""
                    class="size-full object-cover"
                  />
                </span>
              </div>
              <div
                class="bg-base-200 relative flex h-24 cursor-pointer items-center justify-center rounded-lg"
              >
                <span class="sr-only">Back angle open view</span>
                <span class="absolute inset-0 overflow-hidden rounded-lg">
                  <img
                    src="https://tailwindcss.com/plus-assets/img/ecommerce-images/product-page-03-product-04.jpg"
                    alt=""
                    class="size-full object-cover"
                  />
                </span>
              </div>
            </div>
          </div>
          <div
            class="bg-base-200 aspect-square w-full overflow-hidden rounded-lg"
          >
            <img
              src="https://tailwindcss.com/plus-assets/img/ecommerce-images/product-page-03-product-01.jpg"
              alt="Angled front view with bag zipped and handles upright."
              class="aspect-square w-full object-cover"
            />
          </div>
        </div>

        <!-- Product info -->
        <div class="mt-10 px-4 sm:mt-16 sm:px-0 lg:mt-0">
          <h1 class="text-base-content text-3xl font-bold tracking-tight">
            Zip Tote Basket
          </h1>

          <div class="mt-3">
            <h2 class="sr-only">Product information</h2>
            <p class="text-base-content text-3xl tracking-tight">$140</p>
          </div>

          <div class="mt-6">
            <!-- Colors -->
            <div>
              <h3 class="text-base-content/70 text-sm font-medium">Color</h3>
              <fieldset aria-label="Choose a color" class="mt-2">
                <div class="flex items-center gap-3">
                  <label
                    class="outline-base-content/10 flex rounded-full outline outline-1 -outline-offset-1"
                  >
                    <input
                      type="radio"
                      name="color"
                      value="washed-black"
                      checked
                      aria-label="Washed Black"
                      class="radio radio-primary bg-base-300 size-8 rounded-full"
                    />
                  </label>
                  <label
                    class="outline-base-content/10 flex rounded-full outline outline-1 -outline-offset-1"
                  >
                    <input
                      type="radio"
                      name="color"
                      value="white"
                      aria-label="White"
                      class="radio radio-primary bg-base-100 size-8 rounded-full"
                    />
                  </label>
                  <label
                    class="outline-base-content/10 flex rounded-full outline outline-1 -outline-offset-1"
                  >
                    <input
                      type="radio"
                      name="color"
                      value="washed-gray"
                      aria-label="Washed Gray"
                      class="radio radio-primary bg-base-300 size-8 rounded-full"
                    />
                  </label>
                </div>
              </fieldset>
            </div>

            <div class="mt-10">
              <button type="button" class="btn btn-primary w-full"
                >Add to bag</button
              >
            </div>
          </div>

          <div class="mt-6">
            <h3 class="sr-only">Description</h3>
            <div class="text-base-content/80 space-y-6 text-base">
              <p>
                The Zip Tote Basket is the perfect midpoint between shopping
                tote and comfy backpack. With convertible straps, you can hand
                carry, should sling, or backpack this convenient and spacious
                bag. The zip top and durable canvas construction keeps your
                goods protected for all-day use.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
